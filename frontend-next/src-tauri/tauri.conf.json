{
  "productName": "TranscribeAlpha",
  "version": "0.2.9",
  "identifier": "com.transcribealpha.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "TranscribeAlpha",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:18080 http://127.0.0.1:18080 https://api.assemblyai.com https://*.anthropic.com https://*.googleapis.com; img-src 'self' data: blob:; media-src 'self' blob: asset: http://asset.localhost; font-src 'self' data:; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/transcribealpha-server"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwQ0RDQkVGN0VDREMxRjMKUldUendjMSs3OHZOb01scEF2dEt0NzM4OUZST0RSenlsYnplL1p6SGNtc0FQZWFpQWZ1WlJlR2MK",
      "endpoints": [
        "https://github.com/nathanjeichert/TranscribeAlpha2.0/releases/latest/download/latest.json"
      ]
    }
  }
}
